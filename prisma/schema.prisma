generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ticket {
  ticketId  String   @id
  licensePlateNumber String?
  licensePlateState  String?
  lat                Float?
  lng                Float?
  streetLocation     String?
  timestamp DateTime @default(now())
}

model ScraperState {
  id            Int    @id @default(1)
  lastCheckedId String
  status        String
}

model FcmEnrollment {
  id             Int      @id @default(autoincrement())
  fcmToken       String
  streetLocation String
  createdAt      DateTime @default(now())

  @@unique([fcmToken, streetLocation])
}

model Notification {
  id             Int      @id @default(autoincrement())
  fcmToken       String
  title          String
  body           String
  streetLocation String
  ticketId       String
  sentAt         DateTime @default(now())
}
