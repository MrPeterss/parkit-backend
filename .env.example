# Server Configuration
PORT=8000
NODE_ENV=development

# Database Configuration
# For local development, use a local SQLite file
# For production, this is mounted as a volume in Docker
DATABASE_URL=file:./prisma/data/sqlite.db

# Logging Configuration
# Set to "true" to enable query logging (only works in development)
PRISMA_LOG_QUERIES=true
# Set to "false" to disable error logging
PRISMA_LOG_ERRORS=true
# Set to "false" to disable warning logging
PRISMA_LOG_WARNINGS=true

# 2Captcha Configuration (Optional)
# Get API key from: https://2captcha.com/
# Used for automatic CAPTCHA solving during ticket scraping
TWOCAPTCHA_API_KEY=

# LocationIQ — Nominatim-based forward geocoding with street geometry (polygon_geojson=1)
# https://locationiq.com/ — create a project and copy the access token
LOCATIONIQ_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Ticket scraper — lane-based scheduling
# ---------------------------------------------------------------------------
# A "lane" = one 500-wide block of ticket IDs issued by one device/officer.
# The scraper runs many lanes in parallel, polling each at a decaying cadence
# and discovering new lanes as they come online.

# Ticket ID used to bootstrap the first lane on a fresh database (also used
# as the initial cursor within that lane).
DEFAULT_START_TICKET_ID=

# Optional comma-separated list of ticket IDs. Each becomes a seed lane for
# the block it belongs to. Overrides DEFAULT_START_TICKET_ID when both set.
# Example: LANE_BOOTSTRAP_BLOCK_STARTS=100000064501,100000065001
LANE_BOOTSTRAP_BLOCK_STARTS=100000064741,100000065059,100000063450

# Poll cadence decay — comma-separated ms values. On each confirmed miss the
# lane advances one level (capped at the last). A hit resets to level 0.
# Default: 2s, 10s, 30s, 1m, 5m, 15m, 30m.
LANE_CADENCE_LEVELS_MS=2000,10000,30000,60000

# Random jitter added to each scheduled nextDueAt (± fraction, 0..1).
LANE_JITTER_PCT=0.15

# Discovery — how many blocks past the frontier to probe per sweep.
LANE_LOOKAHEAD_BLOCKS=3

# Discovery — how many IDs at the head of a candidate block to probe.
LANE_DISCOVERY_PROBE_COUNT=3

# Minimum gap between discovery sweeps (ms).
LANE_DISCOVERY_INTERVAL_MS=90000

# Tail handling — within this many IDs of blockEnd a lane is "at tail":
# - cadence is capped at LANE_TAIL_MAX_CADENCE_MS
# - retirement kicks in faster (LANE_TAIL_RETIRE_AFTER_MS)
LANE_TAIL_THRESHOLD=20
LANE_TAIL_MAX_CADENCE_MS=300000
LANE_TAIL_RETIRE_AFTER_MS=14400000

# Hard retirement — any lane with no hits for this long gets retired.
LANE_MAX_IDLE_MS=172800000